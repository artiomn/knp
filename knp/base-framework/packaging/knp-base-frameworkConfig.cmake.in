#
# CMake version reading functions. Artiom N.(cl)2024
#

@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# ------------------------------------------------------------------
# Dependencies
# ------------------------------------------------------------------

find_package(Boost @KNP_BOOST_MIN_VERSION@ REQUIRED)

# ------------------------------------------------------------------
# Package information
# ------------------------------------------------------------------

set(KNP_BASE_FRAMEWORK_FOUND TRUE)

# ------------------------------------------------------------------
# Imported targets
# ------------------------------------------------------------------

include("${CMAKE_CURRENT_LIST_DIR}/knp-base-framework-devTargets.cmake")
include("${CMAKE_CURRENT_LIST_DIR}/knp-base-framework-devTargets-debug.cmake")

add_library(KNP::BaseFramework::Core ALIAS KNP::knp-base-framework-core)
add_library(KNP::BaseFramework::CoreStatic ALIAS KNP::knp-base-framework-core_static)

# ------------------------------------------------------------------
# Legacy compatibility variables (optional)
# ------------------------------------------------------------------

get_filename_component(
    KNP_BASE_FRAMEWORK_CMAKE_DIR
    "${CMAKE_CURRENT_LIST_FILE}"
    PATH
)

set(
    KNP_BASE_FRAMEWORK_INCLUDE_DIRS
    "@PACKAGE_INCLUDE_INSTALL_DIR@"
)

# ------------------------------------------------------------------
# Components support
# ------------------------------------------------------------------

check_required_components(knp-base-framework)
